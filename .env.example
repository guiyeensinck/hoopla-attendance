# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# App config
PORT=3000
APP_URL=https://hoopla-attendance-production.up.railway.app

# Channel for reports and alerts
REPORT_CHANNEL=#asistencia

# Solo mode (for testing)
SOLO_MODE=true
SOLO_USER_ID=U0ABC1DEF2

# Admin users (comma-separated Slack IDs, always have admin access)
ADMIN_USER_IDS=U0ABC1DEF2

# Desktop verification
PIN_ROTATION_MIN=5        # Minutes between PIN changes

# Activity monitoring
PINGS_PER_DAY=3           # Random pings per person per day
PING_TIMEOUT_MIN=10       # Minutes to respond before marked as missed
WORK_START_HOUR=9         # Work hours start (24h)
WORK_END_HOUR=18          # Work hours end (24h)
MAX_HOURS_PER_DAY=9       # Alert if someone exceeds this
EXPECTED_HOURS_PER_DAY=8  # Standard workday for balance calculation
